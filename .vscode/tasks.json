{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --build build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -B build",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}

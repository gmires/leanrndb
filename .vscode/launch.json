{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug REPL",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/leanrndb",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {"name": "DEBUGINFOD_URLS", "value": ""}
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${workspaceFolder}/.vscode/gdb-wrapper.sh",
            "setupCommands": [
                {
                    "description": "Disable debuginfod before anything",
                    "text": "set debuginfod enabled off",
                    "ignoreFailures": true
                },
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build"
        },
        {
            "name": "Debug REPL (no build)",

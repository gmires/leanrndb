{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug REPL",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/leanrndb",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug one-shot query",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/leanrndb",
            "args": [
                "${workspaceFolder}/debug.db",
                "SELECT * FROM t;"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build",
            "miDebuggerPath": "/usr/bin/gdb"
        },
